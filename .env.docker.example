# Copy this file to .env on the server before running docker compose.
APP_PORT=8787

POSTGRES_DB=exercise_monitor
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_USER=exercise_monitor
POSTGRES_PASSWORD=replace_with_a_long_random_password
POSTGRES_PORT=55432

DATABASE_URL=postgresql://exercise_monitor:replace_with_a_long_random_password@postgres:5432/exercise_monitor
RAG_DATABASE_URL=postgresql://exercise_monitor:replace_with_a_long_random_password@postgres:5432/exercise_monitor
CORS_ORIGINS=http://localhost:8787

# Use "off" to start without an AI provider. Use "api-key" after setting keys below.
AGENT_AUTH_MODE=off

# Option A: ccswitch-style provider list.
# CCSWITCH_PROVIDERS_JSON=[{"id":"openai","provider":"openai","displayName":"OpenAI","model":"gpt-4o-mini","baseUrl":"https://api.openai.com/v1","apiKey":"sk-..."}]
# CCSWITCH_ACTIVE_PROVIDER=openai

# Option B: individual provider env vars.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
