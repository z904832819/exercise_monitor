page {
  background: #0b1220;
  color: #e2e8f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
}
.container {
  padding: 24rpx;
}
.section {
  background: #111827;
  border: 1rpx solid #1f2937;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.btn {
  background: linear-gradient(90deg, #0891b2, #06b6d4);
  color: #fff;
  border: 0;
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  margin-top: 12rpx;
}
.field {
  margin-bottom: 14rpx;
}
.label {
  color: #94a3b8;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
.input {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #334155;
  border-radius: 12rpx;
  background: #020617;
  color: #e2e8f0;
  padding: 16rpx;
}
.btn-ghost {
  border: 1rpx solid #334155;
  background: transparent;
  color: #e2e8f0;
}
.message {
  color: #fca5a5;
  margin-bottom: 12rpx;
}
.list-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #1f2937;
}
.card-meta {
  color: #94a3b8;
  font-size: 22rpx;
}
