DATABASE_URL=postgresql://laixufei@127.0.0.1:5432/exercise_monitor
PORT=8787
AGENT_AUTH_MODE=api-key
AGENT_ACTIVE_PROVIDER=openai
AGENT_ACTIVE_VISION_PROVIDER=gemini

# 方式 1：配置多个供应商（推荐：ccswitch 风格）
CCSWITCH_PROVIDERS_JSON=[{"id":"openai","provider":"openai","displayName":"OpenAI","model":"gpt-4o-mini","baseUrl":"https://api.openai.com/v1","apiKey":"sk-..."}]

# 方式 2：按供应商环境变量（兼容 DeepSeek / Anthropic / OpenAI）
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=你的gemini-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

DEEPSEEK_API_KEY=你的deepseek-key
DEEPSEEK_MODEL=deepseek-chat
